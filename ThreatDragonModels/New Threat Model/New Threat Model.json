              {
                "id": "threat-8",
                "title": "T8 - Credential theft yields impersonated JWT",
                "status": "Open",
                "severity": "High",
                "type": "Spoofing",
                "description": "An attacker steals staff or admin credentials and authenticates to the external IdP, receiving a valid JWT that grants system access under a spoofed identity.",
                "mitigation": "Enforce MFA on IdP. Validate JWT audience and scope claims. Monitor for anomalous login patterns.",
                "modelType": "STRIDE",
                "new": false,
