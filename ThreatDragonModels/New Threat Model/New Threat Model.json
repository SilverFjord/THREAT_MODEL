            "description": "Receives video streams from on-site surveillance cameras. Matches faces against registered guests and staff for physical access control. Returns match/no-match only — never exposes PII.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "Privileged",
            "isWebApplication": false,
            "handlesCardPayment": false,
            "handlesGoodsOrServices": false,
