          {
            "type": "tm.Process",
            "size": { "width": 100, "height": 100 },
            "position": { "x": 220, "y": 150 },
            "angle": 0,
            "id": "process-booking",
            "z": 2,
            "hasOpenThreats": true,
            "description": "Handles online pre-arrival bookings from guests and on-site staff requests. Authenticates via External IdP. Entry point exposed to external network for pre-arrival bookings.",
            "outOfScope": false,
            "reasonOutOfScope": "",
            "privilegeLevel": "Application",
            "isWebApplication": true,
            "handlesCardPayment": true,
            "handlesGoodsOrServices": true,
            "isEncrypted": false,
            "isALog": false,
            "storesInventory": false,
            "threats": [
              {
                "id": "threat-1",
                "title": "T1 - Spoofing of staff identity via stolen credentials",
                "status": "Open",
                "severity": "High",
                "type": "Spoofing",
                "description": "Attacker uses stolen staff credentials from an unattended on-site terminal to spoof a legitimate staff identity and access the Booking API with staff-level privileges.",
                "mitigation": "Enforce MFA. Implement session binding. Auto-lock terminals after inactivity (SR2).",
                "modelType": "STRIDE",
                "new": false,
                "number": 1,
                "score": ""
              },
              {
                "id": "threat-2",
                "title": "T2 - SQL injection via booking request fields",
                "status": "Open",
                "severity": "High",
                "type": "Tampering",
                "description": "Attacker submits crafted input in booking request fields passed unsanitised to the database layer, enabling modification or exfiltration of booking and guest records.",
                "mitigation": "Use parameterised queries and ORM. Input validation and sanitisation.",
                "modelType": "STRIDE",
                "new": false,
                "number": 2,
                "score": ""
              },
              {
                "id": "threat-3",
                "title": "T3 - Session hijacking at on-site terminal",
                "status": "Open",
                "severity": "Medium",
                "type": "Information Disclosure",
                "description": "Adversary physically accesses an unattended authenticated staff terminal and hijacks the active session, gaining access to booking data and guest pseudonyms without re-authentication.",
                "mitigation": "Short session timeout (SR2). Screen lock after inactivity. Physical access controls on staff terminals.",
                "modelType": "STRIDE",
                "new": false,
                "number": 3,
                "score": ""
              },
              {
                "id": "threat-4",
                "title": "T4 - DDoS disrupts booking and physical access control",
                "status": "Open",
                "severity": "Medium",
                "type": "Denial of Service",
                "description": "A volumetric DDoS attack floods the Booking API, making it unavailable. Since physical access management depends on system availability, this also disrupts on-site access control.",
                "mitigation": "Rate limiting. WAF with DDoS mitigation. Offline fallback access control procedure.",
                "modelType": "STRIDE",
                "new": false,
                "number": 4,
                "score": ""
              }
            ],
            "attrs": {
              "text": { "text": "Booking API" }
            }
          },

