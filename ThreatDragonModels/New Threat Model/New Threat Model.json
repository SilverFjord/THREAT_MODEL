            "isALog": false,
            "storesInventory": false,
            "threats": [
              {
                "id": "threat-9",
                "title": "T9 (AI) - Manipulated video feed bypasses facial recognition",
                "status": "Open",
                "severity": "Critical",
                "type": "Tampering",
                "description": "An attacker injects a manipulated or pre-recorded video feed into the camera stream, causing the AI to match an authorised guest/staff face and grant physical access to an unauthorised individual.",
                "mitigation": "Authenticate camera feeds with signed video streams. Anomaly detection on feed metadata. Confidence threshold enforcement (SR4).",
                "modelType": "STRIDE",
                "new": false,
                "number": 9,
                "score": ""
              },
              {
                "id": "threat-10",
                "title": "T10 (AI) - Model extraction exposes biometric identities",
                "status": "Open",
                "severity": "Critical",
                "type": "Information Disclosure",
                "description": "An adversary with API access systematically queries the AI service with crafted inputs to extract the underlying model via model-stealing attacks, reconstructing biometric embeddings linkable to real guest identities.",
                "mitigation": "Rate-limit and monitor AI API queries. Restrict model access to admins only (SR5). Differential privacy on model outputs.",
                "modelType": "STRIDE",
                "new": false,
                "number": 10,
                "score": ""
              }
            ],
            "attrs": {
              "text": { "text": "AI Facial\nRecognition" }
